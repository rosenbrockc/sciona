AGEOM_INDEX_DIR=data/index
AGEOM_SKILL_INDEX_DIR=data/skill_index
AGEOM_CLRS_PATH=
AGEOM_COQ100_PATH=
AGEOM_POSTGRES_URI=postgresql://localhost:5432/ageom_architect
AGEOM_ARCHITECT_MAX_DEPTH=8
AGEOM_ARCHITECT_LLM_MODEL=claude-sonnet-4-5-20250929

# Global default LLM
AGEOM_LLM_PROVIDER=claude_cli
AGEOM_LLM_MODEL=sonnet

# Local Ollama server
AGEOM_LLAMA_CPP_BASE_URL=http://127.0.0.1:11434/v1
AGEOM_LLAMA_CPP_API_KEY=local
AGEOM_HUNTER_LLM_PROVIDER=claude_cli
AGEOM_HUNTER_LLM_MODEL=sonnet
AGEOM_HUNTER_LLM_MAX_TOKENS=1024
AGEOM_HUNTER_MODE=speculative_local
AGEOM_HUNTER_USE_GBNF=true
AGEOM_HUNTER_QUERY_BATCH_SIZE=40
AGEOM_HUNTER_TOP_K_PER_QUERY=50
AGEOM_HUNTER_MAX_CANDIDATES_TOTAL=3000
AGEOM_HUNTER_TOP_K_VERIFY=10

# Clear per-prompt llama_cpp overrides (fall back to global claude_cli)
AGEOM_INGESTER_HOIST_STATE_LLM_PROVIDER=
AGEOM_INGESTER_ABSTRACT_LLM_PROVIDER=
AGEOM_INGESTER_FIX_TYPE_LLM_PROVIDER=
AGEOM_INGESTER_FIX_GHOST_LLM_PROVIDER=
AGEOM_INGESTER_OPAQUE_WITNESS_LLM_PROVIDER=
AGEOM_INGESTER_FIX_MESSAGE_CYCLE_LLM_PROVIDER=
AGEOM_INGESTER_DECOMPOSE_LLM_PROVIDER=
AGEOM_ARCHITECT_STRATEGY_LLM_PROVIDER=
AGEOM_ARCHITECT_CRITIQUE_LLM_PROVIDER=
AGEOM_HUNTER_SCORE_LLM_PROVIDER=
AGEOM_HUNTER_REFORMULATE_LLM_PROVIDER=
AGEOM_HUNTER_ANALYZE_FAILURE_LLM_PROVIDER=
AGEOM_ORCHESTRATOR_REFINE_LLM_PROVIDER=
