# =============================================================================
# docker/.env.example — Copy to .env and fill in real values
# =============================================================================

# --- Domain ------------------------------------------------------------------
DOMAIN=yourdomain.com

# --- Proxy / ACME ------------------------------------------------------------
ACME_EMAIL=admin@yourdomain.com

# --- Authentik ----------------------------------------------------------------
AUTHENTIK_PG_PASSWORD=change-me-authentik-pg
AUTHENTIK_SECRET_KEY=change-me-generate-64-char-random-string

# --- Temporal -----------------------------------------------------------------
TEMPORAL_PG_PASSWORD=change-me-temporal-pg

# --- Sentry ------------------------------------------------------------------
# Public hostname used by the self-hosted nginx container behind the shared
# reverse proxy.
SENTRY_HOSTNAME=sentry.${DOMAIN}

# Upstream getsentry/self-hosted version used by docker/sentry/bootstrap.sh.
SENTRY_SELF_HOSTED_VERSION=26.3.1

# DSN consumed by the API runtime after the Sentry project is created.
SENTRY_DSN=
