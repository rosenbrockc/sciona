# Local overrides for an upstream getsentry/self-hosted checkout.
# Copy this file into the cloned self-hosted repo as `.env.custom`.

# Keep the upstream nginx bound to localhost only. External traffic should flow
# through the shared nginx proxy on `proxy-tier`.
SENTRY_BIND=127.0.0.1:9000

# Override the default project name so the container names remain predictable
# across environments.
COMPOSE_PROJECT_NAME=sciona-sentry

# Start with the full stack unless you intentionally want the lighter profile.
COMPOSE_PROFILES=feature-complete

# Keep the version in sync with the upstream checkout tag used by bootstrap.sh.
SENTRY_IMAGE=ghcr.io/getsentry/sentry:26.3.1
SNUBA_IMAGE=ghcr.io/getsentry/snuba:26.3.1
RELAY_IMAGE=ghcr.io/getsentry/relay:26.3.1
SYMBOLICATOR_IMAGE=ghcr.io/getsentry/symbolicator:26.3.1
TASKBROKER_IMAGE=ghcr.io/getsentry/taskbroker:26.3.1
VROOM_IMAGE=ghcr.io/getsentry/vroom:26.3.1
UPTIME_CHECKER_IMAGE=ghcr.io/getsentry/uptime-checker:26.3.1

# Required for outbound email from Sentry notifications.
# SENTRY_MAIL_HOST=sentry.example.com
